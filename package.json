{
  "name": "e-commerce-website",
  "version": "1.0.0",
  "description": "SmartCart AI - Multi-vendor E-Commerce Platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon --ignore data/ server.js",
    "postinstall": "cd frontend && npm install --cache ../.npm-cache --no-audit --no-fund",
    "build-frontend": "cd frontend && npm run build",
    "seed": "node seed/seed.js"
  },
  "dependencies": {
    "axios": "^1.18.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.3.1",
    "multer": "^2.2.0",
    "socket.io": "^4.8.3",
    "twilio": "^6.0.2",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
